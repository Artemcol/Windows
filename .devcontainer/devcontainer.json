{
    "name": "Windows 10 on Docker",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "hostRequirements": {
        "cpus": 2,
        "memory": "8gb",

    },
    "forwardPorts": [8006, 5901],
    "portsAttributes": {
        "8006": {
            "label": "Windows 10 (Web)",
            "onAutoForward": "openBrowser"
        },
        "5901": {
            "label": "Windows 10 (VNC)",
            "onAutoForward": "notify"
        }
    },
    "postCreateCommand": "sudo docker run -d -p 8006:8006 -p 5901:5900 --name windows10 --restart unless-stopped -e VERSION=\"10\" -e RESOLUTION=\"1366x768\" -e ARGUMENTS=\"-vnc :1\" dockurr/windows",
    "shutdownAction": "stopContainer",
    "containerEnv": {
        "WIN_VERSION": "10",
        "WIN_RESOLUTION": "1366x768"
    }
}
